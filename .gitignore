# --- Project Specific Ignores ---
# Ignore dataset folders (contain large .npz files)
data/

# Ignore experiment runs and outputs (contain large checkpoints, logs, and gifs/pngs)
**/runs/
*.pkl
*.pkl.gz
*.npy
*.npz
*.png
*.gif
# Except if you want to track specific visualizations in the root, uncomment below or add them explicitly:
!verification_pendulum.gif

# Track specific run results (K7_fixed_b_vi_v3)
!/runs/
/runs/*
!/runs/K7_fixed_b_vi_v3/
!/runs/K7_fixed_b_vi_v3/**/*.gif
!/runs/K7_fixed_b_vi_v3/**/*.png
!/runs/K7_fixed_b_vi_v3/**/*.pkl
!/runs/K7_fixed_b_vi_v3/**/*.npy
!/runs/K7_fixed_b_vi_v3/**/*.json
